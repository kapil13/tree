# Native Mac backend — copy to backend/.env
# Postgres.app on port 5432 (recommended — includes PostGIS, no Docker)

APP_ENV=development
APP_DEBUG=true

# Replace YOUR_USER with output of: whoami
# If password has @ use %40 in the URL
DATABASE_URL=postgresql+asyncpg://YOUR_USER@localhost:5432/byot
DATABASE_URL_SYNC=postgresql+psycopg2://YOUR_USER@localhost:5432/byot

REDIS_URL=redis://localhost:6379/0

JWT_SECRET=dev-secret-not-for-production
CORS_ORIGINS=http://localhost:3000

# Leave empty — photo uploads use local stub (no MinIO/S3 needed)
S3_ENDPOINT_URL=
S3_BUCKET_MEDIA=byot-media-local
