# Native Mac backend — copy to backend/.env
# Replace USER and ENCODED_PASSWORD (use %40 for @ in passwords)

APP_ENV=development
APP_DEBUG=true

DATABASE_URL=postgresql+asyncpg://USER:ENCODED_PASSWORD@localhost:5432/byot
DATABASE_URL_SYNC=postgresql+psycopg2://USER:ENCODED_PASSWORD@localhost:5432/byot

REDIS_URL=redis://localhost:6379/0

JWT_SECRET=dev-secret-not-for-production
CORS_ORIGINS=http://localhost:3000

# Leave empty for local dev — photo uploads use stub storage
S3_ENDPOINT_URL=
S3_BUCKET_MEDIA=byot-media-local
