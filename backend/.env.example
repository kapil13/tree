APP_ENV=development
APP_NAME=byot-api
APP_VERSION=1.0.0
APP_DEBUG=true

# Postgres + PostGIS
DATABASE_URL=postgresql+asyncpg://byot:byot@postgres:5432/byot
DATABASE_URL_SYNC=postgresql+psycopg2://byot:byot@postgres:5432/byot

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET=change-me-in-prod-please
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS
CORS_ORIGINS=http://localhost:3000

# AWS / S3
AWS_REGION=ap-south-1
S3_BUCKET_MEDIA=byot-media-local
S3_ENDPOINT_URL=http://minio:9000
AWS_ACCESS_KEY_ID=byotadmin
AWS_SECRET_ACCESS_KEY=byotadmin123

# AI providers (optional in dev; service falls back to stub)
OPENAI_API_KEY=
GEMINI_API_KEY=

# Satellite providers (optional in dev; service falls back to stub)
SENTINEL_HUB_CLIENT_ID=
SENTINEL_HUB_CLIENT_SECRET=
SENTINEL_HUB_API_URL=https://sh.dataspace.copernicus.eu
SENTINEL_HUB_TOKEN_URL=https://identity.dataspace.copernicus.eu/auth/realms/CDSE/protocol/openid-connect/token
GEE_SERVICE_ACCOUNT_JSON=

# Weather (Open-Meteo — free, no API key required)
OPEN_METEO_API_URL=https://api.open-meteo.com/v1

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# Notifications
SES_SENDER=no-reply@byot.earth
SNS_SMS_SENDER_ID=BYOT
FCM_SERVER_KEY=

# Bioacoustic — BirdNET bird identification (production default)
BIOACOUSTIC_PIPELINE=birdnet
BIOACOUSTIC_MIN_CONFIDENCE=0.15
BIOACOUSTIC_RETURN_ALL_DETECTIONS=true
BIOACOUSTIC_NOISE_REDUCTION=false
BIOACOUSTIC_ENABLE_FROGS=false
BIOACOUSTIC_ENABLE_INSECTS=false
BIOACOUSTIC_ENABLE_PERCH=false
BIOACOUSTIC_PERCH_MODEL_PATH=/opt/aranyix/models/perch_v2_no_dft.onnx
BIOACOUSTIC_PERCH_LABELS_PATH=/opt/aranyix/models/perch_labels.txt
BIOACOUSTIC_PERCH_MIN_CONFIDENCE=0.20
BIOACOUSTIC_PERCH_TAXA=amphibian,mammal,insect,reptile
IUCN_API_TOKEN=

# ISRO Bhoonidhi STAC catalog (register VPS IP with bhoonidhi@nrsc.gov.in)
BHOONIDHI_USER_ID=
BHOONIDHI_PASSWORD=
BHOONIDHI_API_URL=https://bhoonidhi-api.nrsc.gov.in
