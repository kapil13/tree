# ── Domains (point A records to your VPS public IP) ─────────────────────────
APP_DOMAIN=aranyix.tech
API_DOMAIN=api.aranyix.tech
FRONTEND_URL=https://aranyix.tech
# Optional: public MinIO for presigned browser uploads (same IP, Caddy → minio:9000)
MEDIA_DOMAIN=media.byot.earth

# ── Public URLs (used at frontend build time — rebuild after changing) ───────
# Same-origin is most reliable: browser calls https://aranyix.tech/api/... (Next.js proxies to backend).
# Do NOT use https://api.aranyix.tech here unless you need a separate API subdomain in the browser.
NEXT_PUBLIC_API_URL=https://aranyix.tech
CORS_ORIGINS=https://aranyix.tech,https://www.aranyix.tech

# ── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=byot
POSTGRES_PASSWORD=CHANGE_ME_use_openssl_rand_hex_32
POSTGRES_DB=byot

# ── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_use_openssl_rand_hex_32
GOOGLE_REDIRECT_URI=https://api.aranyix.tech/api/v1/auth/google/callback

# ── MinIO (internal S3-compatible storage) ───────────────────────────────────
MINIO_ROOT_USER=byotadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_strong_minio_password
S3_BUCKET_MEDIA=byot-media

# ── Google Maps (frontend build arg) ────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ── CAPTCHA (Cloudflare Turnstile) ─────────────────────────────────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Google OAuth (backend) ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match Authorized redirect URI in Google Cloud Console exactly:
# https://api.aranyix.tech/api/v1/auth/google/callback

# ── Satellite (Copernicus Data Space) ───────────────────────────────────────
SENTINEL_HUB_CLIENT_ID=
SENTINEL_HUB_CLIENT_SECRET=
SENTINEL_HUB_API_URL=https://sh.dataspace.copernicus.eu
SENTINEL_HUB_TOKEN_URL=https://identity.dataspace.copernicus.eu/auth/realms/CDSE/protocol/openid-connect/token

# ── AI (optional) ───────────────────────────────────────────────────────────
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── Bioacoustic (BirdNET + GBIF + IUCN) ─────────────────────────────────────
# Default deploy uses a slim worker (no TensorFlow). Enable ML only when needed:
#   COMPOSE_PROFILES=bioacoustic ./deploy.sh
# Then run download-perch-model.sh if using Perch v2.
BIOACOUSTIC_PIPELINE=birdnet
BIOACOUSTIC_MIN_CONFIDENCE=0.15
BIOACOUSTIC_RETURN_ALL_DETECTIONS=true
BIOACOUSTIC_NOISE_REDUCTION=false
BIOACOUSTIC_ENABLE_FROGS=false
BIOACOUSTIC_ENABLE_INSECTS=false
# Perch v2 multi-taxa (amphibians, mammals, insects, reptiles) — run download-perch-model.sh first
BIOACOUSTIC_ENABLE_PERCH=false
BIOACOUSTIC_PERCH_MODEL_PATH=/opt/aranyix/models/perch_v2_no_dft.onnx
BIOACOUSTIC_PERCH_LABELS_PATH=/opt/aranyix/models/perch_labels.txt
BIOACOUSTIC_PERCH_MIN_CONFIDENCE=0.20
BIOACOUSTIC_PERCH_TAXA=amphibian,mammal,insect,reptile
BIOACOUSTIC_REVIEW_CONFIDENCE=0.70
# PERCH_MODEL_HOST_DIR=/opt/aranyix/models
IUCN_API_TOKEN=
IUCN_API_URL=https://api.iucnredlist.org/api/v4
GBIF_API_URL=https://api.gbif.org/v1
GBIF_OCCURRENCE_RADIUS_KM=25

# ── ISRO Bhoonidhi (optional — IRS / ResourceSat catalog) ───────────────────
# Register VPS public IPv4 with bhoonidhi@nrsc.gov.in before enabling
BHOONIDHI_USER_ID=
BHOONIDHI_PASSWORD=
BHOONIDHI_API_URL=https://bhoonidhi-api.nrsc.gov.in

# ── Notifications (optional — without AWS creds, email/SMS are dev stubs) ───
SES_SENDER=no-reply@byot.earth
SNS_SMS_SENDER_ID=BYOT
FCM_SERVER_KEY=

# ── AWS region (used by notifier SDK if you add SES/SNS later) ────────────────
AWS_REGION=ap-south-1
