# Caddy reverse proxy + automatic HTTPS (Let's Encrypt)
# Domains are injected via environment variables from .env.production

{$APP_DOMAIN} {
	encode gzip zstd
	reverse_proxy frontend:3000
}

www.{$APP_DOMAIN} {
	redir https://{$APP_DOMAIN}{uri} permanent
}

{$API_DOMAIN} {
	encode gzip zstd
	reverse_proxy backend:8000
}

# Optional: uncomment after setting MEDIA_DOMAIN in .env.production and DNS A record
# {$MEDIA_DOMAIN} {
# 	encode gzip
# 	reverse_proxy minio:9000
# }
